        },
        {
          "name": "POST Member Positive",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Member {{$guid}}\",\n  \"email\": \"{{$randomEmail}}\",\n  \"status\": \"ACTIVE\",\n  \"outstandingFees\": 0.00\n}"
