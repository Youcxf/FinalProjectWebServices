      "name": "Gateway And Smoke",
      "item": [
        {
          "name": "Bootstrap And List Routes",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = Date.now().toString();",
                  "pm.collectionVariables.set('runId', runId);",
                  "pm.collectionVariables.set('dynamicMemberName', `Postman Member ${runId}`);",
                  "pm.collectionVariables.set('dynamicMemberEmail', `postman.member.${runId}@example.com`);",
                  "pm.collectionVariables.set('dynamicMemberUpdatedEmail', `postman.member.updated.${runId}@example.com`);",
                  "pm.collectionVariables.set('dynamicBookTitle', `Postman Book ${runId}`);",
                  "pm.collectionVariables.set('dynamicBookUpdatedTitle', `Postman Book Updated ${runId}`);",
                  "['createdMemberId', 'createdBookId', 'createdLoanId', 'createdDecisionId', 'rejectedDecisionId', 'createdDecisionLoanId'].forEach((key) => pm.collectionVariables.unset(key));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expected result: Bootstrap And List Routes', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array').with.length(4);",
                  "  pm.expect(json.map((route) => route.service)).to.include.members(['member-service', 'catalog-service', 'borrowing-service', 'library-orchestrator']);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{gatewayUrl}}/api/v1/routes"
          }
        },
